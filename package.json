{
  "name": "ackerkreis",
  "version": "0.1.0",
  "private": true,
  "description": "Management system for a solidarity farming community",
  "scripts": {
    "dev": "pnpm --filter ./app dev",
    "build": "pnpm --filter ./app build",
    "start": "pnpm --filter ./app start",
    "lint": "pnpm --filter ./app lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter ./app db:migrate",
    "db:migrate:deploy": "pnpm --filter ./app db:migrate:deploy",
    "db:generate": "pnpm --filter ./app db:generate",
    "db:seed": "pnpm --filter ./app db:seed",
    "db:studio": "pnpm --filter ./app db:studio"
  },
  "devDependencies": {
    "prettier": "^3.4.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
